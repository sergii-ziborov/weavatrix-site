// Cloudflare deploy config for the weavatrix.com landing (static assets Worker).
// Deploy: npx wrangler deploy   (requires `npx wrangler login` once)
// The custom_domain route auto-creates DNS + cert for weavatrix.com on this account's zone.
{
  "name": "weavatrix",
  "compatibility_date": "2026-07-01",
  "assets": {
    "directory": "./site"
  },
  "routes": [
    { "pattern": "weavatrix.com", "custom_domain": true },
    { "pattern": "www.weavatrix.com", "custom_domain": true }
  ]
}
